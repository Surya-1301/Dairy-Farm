{
  "firestore": {
    "rules": "backend/firestore.rules"
  },
  "functions": {
    "source": "backend/functions"
  },
  "hosting": {
    "public": "frontend/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/__/auth/action",
        "destination": "/reset-redirect.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
