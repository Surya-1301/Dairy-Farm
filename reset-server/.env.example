# Paste the full JSON content of your Firebase service account key here, on one line.
# Firebase Console -> Project settings -> Service accounts -> Generate new private key.
# This is only used server-side and must never be committed or exposed to the frontend.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account", ...}

# Comma-separated list of origins allowed to call this server.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://dairy-farm.tech,https://www.dairy-farm.tech,https://dairy-farm-qlw1.onrender.com

# Optional. Render sets PORT automatically; only needed for local runs.
PORT=8787
